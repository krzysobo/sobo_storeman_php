{
    "name": "krzysobo/sobo_storeman",
    "description": "storage manager for AWS and other solutions",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Dto\\": "src/dto/",
            "App\\Exceptions\\": "src/exceptions/",
            "App\\Helper\\": "src/helper/",
            "App\\Http\\": "src/http/",
            "App\\Middleware\\": "src/middleware/",
            "App\\Routes\\": "src/routes/",
            "App\\Settings\\": "src/",
            "App\\Traits\\": "src/traits/"
        },
        "files": [
            "src/settings.php"
        ]
    },
    "authors": [
        {
            "name": "Krzysztof Sobolewski",
            "email": "krzysztof.sobolewski@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "aws/aws-sdk-php": "^3.370",
        "firebase/php-jwt": "^7.0",
        "defuse/php-encryption": "^2.4",
        "guzzlehttp/psr7": "^2.8",
        "php-di/slim-bridge": "^3.4",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpunit/phpunit": "^11",
        "friendsofphp/php-cs-fixer": "^3.94",
        "zircote/swagger-php": "^4.10"
    },
    "scripts": {
        "openapi": "vendor/bin/openapi src/ --format json -o openapi.json"
    }
}